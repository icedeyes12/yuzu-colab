   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🎯 Yuzu Memory Rebuild - Colab Edition\\n",
    "\\n",
    "**Workflow:**\\n",
    "1. Pull messages from Supabase\\n",
    "2. Generate embeddings with BGE-M3\\n",
    "3. Save to local DuckDB\\n",
    "4. Push back to Supabase\\n",
    "\\n",
    "**Runtime: ~20-30 min**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 🔐 Secrets Setup\\n",
    "from google.colab import userdata\\n",
    "import os\\n",
    "\\n",
    "# Supabase credentials\\n",
    "SUPABASE_URL = userdata.get('SUPABASE_URL')\\n",
    "SUPABASE_KEY = userdata.get('SUPABASE_KEY')\\n",
    "os.environ['SUPABASE_URL'] = SUPABASE_URL\\n",
    "os.environ['SUPABASE_KEY'] = SUPABASE_KEY\\n",
    "print(f\"✅ Supabase URL: {SUPABASE_URL[:30]}...\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 📦 Install Dependencies\\n",
    "!pip install -q duckdb psycopg2-binary sentence-transformers numpy pandas\\n",
    "print(\"✅ Dependencies installed\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 🧠 Load BGE-M3 Model\\n",
    "from sentence_transformers import SentenceTransformer\\n",
    "import torch\\n",
    "\\n",
    "# Use T4 GPU\\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\\n",
    "print(f\"Device: {device}\")\\n",
    "\\n",
    "model = SentenceTransformer(\"BAAI/bge-m3\", device=device)\\n",
    "EMBEDDING_DIM = 1024\\n",
    "print(f\"✅ Model loaded: BAAI/bge-m3 ({EMBEDDING_DIM} dims)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 📥 Phase 1: Pull from Supabase\\n",
    "import psycopg2\\n",
    "from psycopg2.extras import RealDictCursor\\n",
    "import pandas as pd\\n",
    "import duckdb\\n",
    "\\n",
    "# Connect to Supabase\\n",
    "conn = psycopg2.connect(SUPABASE_URL, sslmode='require')\\n",
    "print(\"✅ Connected to Supabase\")\\n",
    "\\n",
    "# Fetch all messages\\n",
    "query = \"\"\"\\n",
    "  SELECT m.id, m.session_id, m.role, m.content, m.created_at, cs.title\\n",
    "  FROM messages m\\n",
    "  JOIN chat_sessions cs ON m.session_id = cs.id\\n",
    "  WHERE cs.user_id = 1\\n",
    "  ORDER BY m.created_at DESC\\n",
    "\"\"\"\\n",
    "df = pd.read_sql(query, conn)\\n",
    "print(f\"📥 Pulled {len(df)} messages\")\\n",
    "conn.close()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 💾 Phase 2: Save to Local DuckDB\\n",
    "local_db = duckdb.connect(\"yuzu_memories.duckdb\")\\n",
    "\\n",
    "# Create tables\\n",
    "local_db.execute(\"\"\"\\n",
    "  CREATE TABLE IF NOT EXISTS messages_raw (\\n",
    "    id INTEGER,\\n",
    "    session_id INTEGER,\\n",
    "    role VARCHAR,\\n",
    "    content TEXT,\\n",
    "    created_at TIMESTAMP,\\n",
    "    session_title VARCHAR\\n",
    "  )\\n",
    "\"\"\")\\n",
    "\\n",
    "local_db.execute(\"\"\"\\n",
    "  CREATE TABLE IF NOT EXISTS memories (\\n",
    "    id INTEGER,\\n",
    "    user_id INTEGER,\\n",
    "    session_id INTEGER,\\n",
    "    content TEXT,\\n",
    "    embedding FLOAT[1024],\\n",
    "    memory_type VARCHAR,\\n",
    "    importance INTEGER,\\n",
    "    created_at TIMESTAMP\\n",
    "  )\\n",
    "\"\"\")\\n",
    "\\n",
    "# Insert messages\\n",
    "local_db.execute(\"DELETE FROM messages_raw\")\\n",
    "for _, row in df.iterrows():\\n",
    "  local_db.execute(\"\"\"\\n",
    "    INSERT INTO messages_raw VALUES (?, ?, ?, ?, ?, ?)\\",\\n",
    "    [row.id, row.session_id, row.role, row.content, row.created_at, row.title]\\n",
    "  \"\"\")\\n",
    "\\n",
    "print(f\"💾 Saved {len(df)} messages to local DuckDB\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 🧠 Phase 3: Generate Embeddings\\n",
    "from tqdm import tqdm\\n",
    "\\n",
    "# Get messages to embed\\n",
    "messages = local_db.execute(\"\"\"\\n",
    "  SELECT id, session_id, role, content, created_at\\n",
    "  FROM messages_raw\\n",
    "  WHERE length(content) > 10\\n",
    "\"\").fetchall()\\n",
    "print(f\"🧠 Processing {len(messages)} messages...\")\\n",
    "\\n",
    "# Batch embed\\n",
    "batch_size = 32\\n",
    "for i in tqdm(range(0, len(messages), batch_size)):\\n",
    "  batch = messages[i:i+batch_size]\\n",
    "  texts = [m[3] for m in batch] if isinstance(batch[0], tuple) else [b['content'] for b in batch]\\n",
    "  \\n",
    "  embeddings = model.encode(texts, convert_to_numpy=True, show_progress_bar=False)\\n",
    "  \\n",
    "  for j, emb in enumerate(embeddings):\\n",
    "    msg = batch[j]\\n",
    "    local_db.execute(\"\"\"\\n",
    "      INSERT INTO memories VALUES (?, ?, ?, ?, ?, ?, ?, ?)\\",\\n",
    "      [msg[0], 1, msg[1], msg[2], list(emb), 'episodic', 50, msg[4]]\\n",
    "    \"\"\")\\n",
    "\\n",
    "mem_count = local_db.execute(\"SELECT COUNT(*) FROM memories\").fetchone()[0]\\n",
    "print(f\"✅ Embedded {mem_count} memories\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 📤 Phase 4: Push to Supabase\\n",
    "conn = psycopg2.connect(SUPABASE_URL, sslmode='require')\\n",
    "cur = conn.cursor()\\n",
    "\\n",
    "# Get all embedded memories\\n",
    "memories = local_db.execute(\"SELECT * FROM memories\").fetchall()\\n",
    "print(f\"📤 Pushing {len(memories)} memories to Supabase...\")\\n",
    "\\n",
    "# Batch insert\\n",
    "batch_size = 100\\n",
    "for i in range(0, len(memories), batch_size):\\n",
    "  batch = memories[i:i+batch_size]\\n",
    "  args = []\\n",
    "  for m in batch:\\n",
    "    emb_list = list(m[4]) if not isinstance(m[4], list) else m[4]\\n",
    "    args.extend([m[0], m[1], m[2], m[3], emb_list, m[5], m[6]])\\n",
    "  \\n",
    "  values = ','.join(['(%s,%s,%s,%s,%s::vector(1024),%s,%s)'] * len(batch))\\n",
    "  cur.execute(f\"\"\"\\n",
    "    INSERT INTO memories (id, user_id, session_id, content, embedding, memory_type, importance)\\n",
    "    VALUES {values}\\n",
    "    ON CONFLICT DO NOTHING\\n",
    "  \"\"\", args)\\n",
    "  conn.commit()\\n",
    "  print(f\"  Pushed {min(i+batch_size, len(memories))}/{len(memories)}\")\\n",
    "\\n",
    "cur.close()\\n",
    "conn.close()\\n",
    "print(\"🎉 Done! All memories pushed to Supabase\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "#@title 📊 Verify\\n",
    "conn = psycopg2.connect(SUPABASE_URL, sslmode='require')\\n",
    "cur = conn.cursor()\\n",
    "cur.execute(\"SELECT COUNT(*) FROM memories WHERE user_id = 1\")\\n",
    "count = cur.fetchone()[0]\\n",
    "print(f\"📊 Total memories in Supabase: {count}\")\\n",
    "conn.close()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## ✅ Complete!\\n",
    "\\n",
    "All ~7000 messages have been embedded with BGE-M3 and stored in Supabase."
   ]
  }
